<Window x:Class="VerseDeck.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="VerseDeck Companion" Height="940" Width="1540" MinHeight="820" MinWidth="1280"
        Background="#02060A" Loaded="Window_Loaded" Closing="Window_Closing">
    <Window.Resources>
        <SolidColorBrush x:Key="Ink" Color="#F2FCFF"/>
        <SolidColorBrush x:Key="Muted" Color="#9FBCC4"/>
        <SolidColorBrush x:Key="Cyan" Color="#49E7FF"/>
        <SolidColorBrush x:Key="Green" Color="#31F6A5"/>
        <SolidColorBrush x:Key="Red" Color="#FF4C58"/>
        <SolidColorBrush x:Key="Amber" Color="#FFC96A"/>
        <DropShadowEffect x:Key="SoftGlow" Color="#49E7FF" BlurRadius="18" ShadowDepth="0" Opacity="0.35"/>

        <Style x:Key="MicroLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#CC071117"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="BorderBrush" Value="#456E79"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,6"/>
            <Setter Property="Margin" Value="0,4,0,8"/>
            <Setter Property="CaretBrush" Value="#49E7FF"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#CC071117"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="BorderBrush" Value="#456E79"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,4,0,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Chrome" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"/>
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="18"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="ContentSite"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                                <TextBox x:Name="PART_EditableTextBox"
                                         Visibility="Hidden"
                                         Background="Transparent"
                                         Foreground="{TemplateBinding Foreground}"
                                         BorderThickness="0"
                                         Padding="0"
                                         CaretBrush="#49E7FF"
                                         VerticalContentAlignment="Center"/>
                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z" Fill="#49E7FF" Width="8" Height="4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          Width="28"
                                          HorizontalAlignment="Right"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border Background="#0B151B" BorderBrush="#456E79" BorderThickness="1" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="280">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#49E7FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#0B151B"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DDF9FF"/>
            <Setter Property="Margin" Value="0,4,0,6"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="#72060D12"/>
            <Setter Property="BorderBrush" Value="#3349E7FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="SidePanel" TargetType="Border" BasedOn="{StaticResource Panel}">
            <Setter Property="Background" Value="#90060D12"/>
        </Style>

        <Style x:Key="CommandButton" TargetType="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="Background" Value="#14242B"/>
            <Setter Property="BorderBrush" Value="#49E7FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,3,7,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="#30071117"/>
            <Setter Property="Foreground" Value="#49E7FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Background="#9949E7FF" BorderBrush="#CC49E7FF" BorderThickness="1">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <MediaElement x:Name="BackgroundVideo"
                      Source="Assets/VideoUi/space.mp4"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Manual"
                      Stretch="UniformToFill"
                      Volume="0"
                      IsMuted="True"
                      MediaFailed="BackgroundVideo_MediaFailed"
                      MediaEnded="BackgroundVideo_MediaEnded"/>
        <Rectangle Fill="#AA02070C"/>
        <Rectangle>
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.5,0.42" GradientOrigin="0.5,0.4" RadiusX="0.82" RadiusY="0.72">
                    <GradientStop Color="#00000000" Offset="0"/>
                    <GradientStop Color="#88000000" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid Margin="22,18,22,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="76"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="24"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource Panel}" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="430"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="48" Height="48" CornerRadius="8" BorderBrush="#5549E7FF" BorderThickness="1" Background="#B0071117" Margin="0,0,12,0">
                        <Image Source="icon.png" Margin="7" Stretch="Uniform"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="VERSEDECK" Foreground="{StaticResource Ink}" FontSize="27" FontWeight="Black"/>
                            <TextBlock Text=" COMPANION" Foreground="{StaticResource Cyan}" FontSize="27" FontWeight="Light"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="1,2,0,0">
                            <TextBlock x:Name="ActiveProfileText" Text="GLOBAL" Foreground="{StaticResource Cyan}" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text=" / " Foreground="#708A91" FontSize="11"/>
                            <TextBlock x:Name="ShipRoleText" Text="STARTER SHIP" Foreground="{StaticResource Muted}" FontSize="11"/>
                            <TextBlock Text=" / LOCAL VOICE / LAN PANEL" Foreground="#708A91" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="2" BorderBrush="#3349E7FF" BorderThickness="1" CornerRadius="6" Background="#99071117" Padding="12,8" VerticalAlignment="Center">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="SAFE INPUT BUS" Foreground="{StaticResource Cyan}" FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="StatusText" Text="Inicializando" Foreground="{StaticResource Ink}" FontSize="14" Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="VOICE " Foreground="{StaticResource Muted}" FontSize="10"/>
                                <TextBlock x:Name="VoiceTopStatusText" Text="OFFLINE" Foreground="{StaticResource Amber}" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="  LAN " Foreground="{StaticResource Muted}" FontSize="10" Margin="12,0,0,0"/>
                                <TextBlock x:Name="LanTopStatusText" Text="OFFLINE" Foreground="{StaticResource Amber}" FontSize="10" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="286"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="330"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SidePanel}" Margin="0,0,12,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="COMMANDER PROFILE" Foreground="{StaticResource Ink}" FontSize="16" FontWeight="Black"/>
                            <TextBlock Text="Identidad local del deck" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,2,0,12"/>
                            <TextBlock Text="PERFIL GUARDADO" Style="{StaticResource MicroLabel}"/>
                            <ComboBox x:Name="ProfileSelectComboBox" SelectedValuePath="Id">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource Ink}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Style="{StaticResource CommandButton}" Content="Cargar perfil" Click="LoadProfile_Click"/>
                            <TextBlock Text="NOMBRE" Style="{StaticResource MicroLabel}"/>
                            <TextBox x:Name="ProfileNameTextBox"/>
                            <TextBlock Text="NAVE" Style="{StaticResource MicroLabel}"/>
                            <ComboBox x:Name="ShipNameComboBox" IsEditable="True" IsTextSearchEnabled="True"/>
                            <Button Style="{StaticResource CommandButton}" Content="Guardar perfil" Click="SaveProfile_Click"/>
                            <Button Style="{StaticResource CommandButton}" Content="Abrir consola debug" Click="OpenDebugConsole_Click"/>

                            <Border Height="1" Background="#3349E7FF" Margin="0,13,8,12"/>
                            <TextBlock Text="AUDIO FEEDBACK" Foreground="{StaticResource Ink}" FontSize="14" FontWeight="Bold"/>
                            <CheckBox x:Name="WelcomeSoundCheckBox" Content="Sonido de bienvenida al iniciar"/>
                            <CheckBox x:Name="CommandSoundCheckBox" Content="Sonido system al ejecutar comando"/>

                            <Border Height="1" Background="#3349E7FF" Margin="0,13,8,12"/>
                            <TextBlock Text="LEGAL / TOS" Foreground="{StaticResource Amber}" FontSize="14" FontWeight="Bold"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#BFDEE5" FontSize="11" LineHeight="15" Margin="0,8,0,0"
                                       Text="VerseDeck Companion es una aplicacion fan no oficial. No esta afiliada a Cloud Imperium Games, Roberts Space Industries ni Star Citizen. No automatiza gameplay ni modifica el juego."/>
                            <Border BorderBrush="#5531F6A5" BorderThickness="1" CornerRadius="6" Padding="9" Margin="0,10,8,0" Background="#2231F6A5">
                                <TextBlock TextWrapping="Wrap" Foreground="#DFFFF4" FontSize="11" LineHeight="15"
                                           Text="Cada boton o frase ejecuta una sola pulsacion configurable. Sin macros, loops, memoria, inyeccion, hooks ni red del juego."/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Column="1" Margin="0,0,12,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="68"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="140"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Panel}" Padding="14,10">
                        <DockPanel>
                            <StackPanel>
                                <TextBlock Text="PRIMARY MFD" Foreground="{StaticResource Ink}" FontSize="20" FontWeight="Black"/>
                                <TextBlock Text="Botonera manual segura - Star Citizen companion local" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox DockPanel.Dock="Right" x:Name="EditModeCheckBox" Content="Modo editar" Foreground="{StaticResource Amber}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Panel}" Padding="14" Margin="0,10,0,10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="DeckItems" ItemsSource="{Binding}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="4"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Tag="{Binding Id}" Click="DeckButton_Click" Height="92" Margin="7" Cursor="Hand" Background="Transparent" BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid x:Name="Root">
                                                        <Image Source="{Binding ButtonFrameImage}" Stretch="Fill"/>
                                                        <Grid Margin="22,13,20,12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="46"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="16"/>
                                                                <RowDefinition Height="*"/>
                                                                <RowDefinition Height="16"/>
                                                            </Grid.RowDefinitions>
                                                            <DockPanel Grid.ColumnSpan="2">
                                                                <TextBlock Text="{Binding Category}" Foreground="#AFC5CB" FontSize="8" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock DockPanel.Dock="Right" Text="{Binding KeyText}" Foreground="{Binding AccentBrush}" FontSize="9" FontWeight="Bold" Margin="6,0,0,0"/>
                                                            </DockPanel>
                                                            <TextBlock Grid.Row="1" Text="{Binding Name}" Foreground="{StaticResource Ink}" FontSize="15" FontWeight="Black" TextWrapping="Wrap" LineHeight="16" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding VoiceSummary}" Foreground="#9CB2B8" FontSize="9" TextTrimming="CharacterEllipsis"/>
                                                            <Image Grid.Column="1" Grid.Row="1" Source="{Binding IconImage}" Width="36" Height="36" Stretch="Uniform" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.95"/>
                                                        </Grid>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Root" Property="Effect" Value="{StaticResource SoftGlow}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Root" Property="Opacity" Value="0.72"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1.1*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource Panel}" Padding="11" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="COMMAND LOG" Foreground="{StaticResource Ink}" FontSize="13" FontWeight="Bold"/>
                                <ListBox x:Name="CommandLogList" Margin="0,7,0,0" Height="86" Background="#D002070A" Foreground="#DDF9FF" BorderBrush="#223D4B" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource Panel}" Padding="11">
                            <StackPanel>
                                <TextBlock Text="VOICE PHRASES" Foreground="{StaticResource Ink}" FontSize="13" FontWeight="Bold"/>
                                <ListBox x:Name="VoicePhrasesList" Margin="0,7,0,0" Height="86" Background="#D002070A" Foreground="#DDF9FF" BorderBrush="#223D4B" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <Border Grid.Column="2" Style="{StaticResource SidePanel}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="MODULE CORE" Foreground="{StaticResource Ink}" FontSize="14" FontWeight="Black"/>
                            <TextBlock x:Name="SelectedButtonTitle" Text="Selecciona un boton" Foreground="{StaticResource Cyan}" FontSize="18" FontWeight="Black" Margin="0,6,0,2"/>
                            <TextBlock x:Name="SelectedButtonMeta" Text="-" Foreground="{StaticResource Muted}" FontSize="11" Margin="0,0,0,9"/>
                            <TextBlock Text="NOMBRE DEL MODULO" Style="{StaticResource MicroLabel}"/>
                            <TextBox x:Name="SelectedNameTextBox"/>
                            <TextBlock Text="CATEGORIA" Style="{StaticResource MicroLabel}"/>
                            <ComboBox x:Name="SelectedCategoryComboBox" IsEditable="True"/>
                            <TextBlock Text="ICONO" Style="{StaticResource MicroLabel}"/>
                            <ComboBox x:Name="SelectedIconComboBox"/>
                            <TextBlock Text="RECUADRO" Style="{StaticResource MicroLabel}"/>
                            <ComboBox x:Name="SelectedFrameComboBox"/>
                            <TextBlock Text="TECLA" Style="{StaticResource MicroLabel}"/>
                            <TextBox x:Name="SelectedKeyTextBox"/>
                            <TextBlock Text="MODIFICADORES: Ctrl, Shift, Alt" Style="{StaticResource MicroLabel}"/>
                            <TextBox x:Name="SelectedModifiersTextBox"/>
                            <CheckBox x:Name="SelectedConfirmCheckBox" Content="Confirmacion secundaria para este modulo"/>
                            <Button Style="{StaticResource CommandButton}" Content="Crear modulo nuevo" Click="CreateModule_Click"/>
                            <Button Style="{StaticResource CommandButton}" Content="Guardar modulo" Click="SaveSelectedButton_Click"/>
                            <Button Style="{StaticResource CommandButton}" Content="Eliminar modulo" Click="DeleteModule_Click"/>

                            <Border Height="1" Background="#3349E7FF" Margin="0,11,8,11"/>
                            <TextBlock Text="VOICE PTT" Foreground="{StaticResource Ink}" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="Nueva frase para el modulo seleccionado" Foreground="{StaticResource Muted}" FontSize="11" Margin="0,3,0,5"/>
                            <TextBox x:Name="VoicePhraseTextBox" Text="bajar tren"/>
                            <TextBlock Text="CONFIANZA MINIMA" Style="{StaticResource MicroLabel}"/>
                            <TextBox x:Name="VoiceConfidenceTextBox" Text="0.40"/>
                            <Button Style="{StaticResource CommandButton}" Content="Anadir frase de voz" Click="SaveVoice_Click"/>
                            <TextBlock Text="MODO DE ACTIVACION" Style="{StaticResource MicroLabel}" Margin="0,6,0,0"/>
                            <ComboBox x:Name="VoiceModeComboBox" SelectedIndex="0">
                                <ComboBoxItem Content="PushToTalk"/>
                                <ComboBoxItem Content="ManualToggle"/>
                            </ComboBox>
                            <TextBlock Text="DISPOSITIVO PTT" Style="{StaticResource MicroLabel}"/>
                            <ComboBox x:Name="PttDeviceComboBox" SelectedIndex="0">
                                <ComboBoxItem Content="Keyboard"/>
                                <ComboBoxItem Content="Mouse"/>
                                <ComboBoxItem Content="Gamepad"/>
                                <ComboBoxItem Content="Joystick"/>
                            </ComboBox>
                            <TextBlock Text="BOTON PTT" Style="{StaticResource MicroLabel}"/>
                            <TextBox x:Name="PttBindingTextBox" Text="F13"/>
                            <Button x:Name="DetectPttButton" Style="{StaticResource CommandButton}" Content="Detectar boton PTT" Click="DetectPttButton_Click"/>
                            <Button Style="{StaticResource CommandButton}" Content="Guardar voz / PTT / Audio" Click="SaveVoiceSettings_Click"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="VoiceButton" Style="{StaticResource CommandButton}" Content="Activar voz" Click="VoiceButton_Click"/>
                                <Button Style="{StaticResource CommandButton}" Content="Bloquear voz" Click="StopVoice_Click"/>
                            </StackPanel>
                            <TextBlock x:Name="VoiceStatusText" Text="Voz detenida" Foreground="{StaticResource Muted}" FontSize="11" Margin="0,5,0,0"/>

                            <Border Height="1" Background="#3349E7FF" Margin="0,11,8,10"/>
                            <TextBlock Text="MOBILE LINK" Foreground="{StaticResource Ink}" FontSize="14" FontWeight="Bold"/>
                            <TextBlock x:Name="MobileUrlText" Text="Servidor detenido" Foreground="{StaticResource Cyan}" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,7"/>
                            <Border Width="132" Height="132" HorizontalAlignment="Left" Background="#F5FFFFFF" BorderBrush="#5549E7FF" BorderThickness="1" CornerRadius="5" Padding="9">
                                <Image x:Name="QrImage" Stretch="Uniform"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="0,7,0,0">
                                <Button x:Name="ServerButton" Style="{StaticResource CommandButton}" Content="Activar servidor" Click="ServerButton_Click"/>
                                <Button Style="{StaticResource CommandButton}" Content="Desconectar" Click="StopServer_Click"/>
                            </StackPanel>
                            <TextBlock x:Name="PinText" Foreground="{StaticResource Muted}" FontSize="11" Margin="0,3,0,0"/>
                            <TextBlock x:Name="DevicesText" Foreground="{StaticResource Muted}" FontSize="11" Margin="0,4,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="4,6,4,0">
                <TextBlock Text="PERMITTED ACTIONS: one direct human-triggered key press per button or voice command. No gameplay automation, no loops, no game memory, no injection, no network interception."
                           Foreground="#8EAAB2" FontSize="10"/>
                <TextBlock Text="Creada con mucho amor por Zowix" HorizontalAlignment="Right" Foreground="{StaticResource Amber}" FontSize="10" FontWeight="Bold"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
